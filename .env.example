# Database
DATABASE_URL=postgresql://tradeapp:tradeapp@localhost:5432/tradeapp

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Backend Server
PORT=3000
NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:5173

# Maps API (choose one)
# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Or Mapbox
MAPBOX_TOKEN=your-mapbox-token

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
PLATFORM_FEE_PERCENT=10
FRONTEND_URL=http://localhost:5173

# Stripe (frontend — Vite needs VITE_ prefix)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=noreply@tradeapp.co.uk

# Admin Account (seeded at startup if not already exists)
ADMIN_EMAIL=admin@tradeapp.co.uk
ADMIN_INITIAL_PASSWORD=ChangeMe123!

# Security
# Set to 'false' if NOT behind a reverse proxy, or a number (e.g. 1) if you are
TRUST_PROXY=1
